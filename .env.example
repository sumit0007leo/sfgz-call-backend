# Copy this file to ".env" and fill in your Twilio credentials.
# Find SID + Auth Token at https://console.twilio.com (Account Info).

# ── Option A (recommended): OmniDimension AI voice agent ──────────────
# If set, the backend dispatches calls through your pre-built agent (ID 193150,
# "SF Game Zone — Booking Confirmer"). Get your API key from the OmniDimension
# dashboard → Settings → API Keys. This alone is enough — Twilio vars below
# are only needed for the fallback path.
OMNIDIM_API_KEY=
OMNIDIM_AGENT_ID=193150
OMNIDIM_BASE_URL=https://backend.omnidim.io

# ── Option B (fallback): your own Twilio number ───────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

PORT=3000
